{
  "name": "pomodoro",
  "version": "1.0.0",
  "description": "番茄钟桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.pomodoro.app",
    "productName": "番茄钟",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "pomodoro.html",
      "assets/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/fanqie.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
